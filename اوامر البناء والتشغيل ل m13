 هذه الأوامر المتاحة بعد تشغيل الدرايفر عبر NSH Console:


# تشغيل الدرايفر
xqpower_can start

# === أوامر التحكم بالزوايا ===

# تحريك سيرفو واحد لزاوية معينة (الفهرس 0-3)
xqpower_can move 0 15      # سيرفو 0 -> 15°
xqpower_can move 1 -20     # سيرفو 1 -> -20°
xqpower_can move 2 0       # سيرفو 2 -> 0°

# تحريك كل السيرفوهات لنفس الزاوية
xqpower_can move_all 10    # الكل -> +10°
xqpower_can move_all -25   # الكل -> -25°

# تصفير كل السيرفوهات (0°)
xqpower_can zero

# حركة سلسة (sweep) من 0 إلى ±الزاوية والعودة
xqpower_can sweep 25       # 0 -> +25 -> -25 -> 0 (حركة سلسة)

# اختبار تلقائي
xqpower_can test           # 0 -> +10 -> -10 -> 0

# عرض الحالة (موقع، تيار، حرارة)
xqpower_can status

# إيقاف الدرايفر
xqpower_can stop






الأمر	الوصف
xqpower_can start	تشغيل الدرايفر
xqpower_can stop	إيقاف الدرايفر
xqpower_can status	عرض حالة كل سيرفو (الموقع، التيار، الحرارة، Online/Offline)
xqpower_can move <idx> <deg>	تحريك سيرفو واحد لزاوية محددة مع التثبيت (idx = 0-3)
xqpower_can move_all <deg>	تحريك جميع السيرفوات لنفس الزاوية
xqpower_can zero	تصفير جميع السيرفوات (0°) مع التثبيت
xqpower_can test	اختبار تلقائي: 0° → +10° → -10° → 0° (ثانية لكل وضع)
xqpower_can sweep <deg>	مسح سلس: 0 → +deg → -deg → 0 بخطوة 1° كل 30ms
xqpower_can calibrate	تعيين الموقع الحالي كنقطة صفر جديدة (يحفظ في Flash)
xqpower_can release	إلغاء التحكم اليدوي والعودة للتحكم الطبيعي (من RocketGNC)
xqpower_can send_test <idx> <deg>	إرسال إطار CAN واحد مع انتظار الرد (للتشخيص)
